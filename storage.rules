rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Comprobantes (F3): subida y borrado pasan SOLO por el servidor (Admin SDK, que
    // bypassa estas reglas). El cliente no escribe ni borra directo. La lectura usa
    // URLs con download-token (no pasan por reglas); acá denegamos escritura al cliente.
    match /users/{userId}/comprobantes/{file} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write, delete: if false;
    }

    // Foto de perfil del usuario (copiada de Google o subida). Imagen hasta 5 MB.
    match /users/{userId}/avatar.jpg {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Todo lo demás, denegado.
    match /{allPaths=**} { allow read, write: if false; }
  }
}
