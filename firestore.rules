rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuario solo puede leer/escribir bajo su propio árbol (users/<su-uid>/**).
    // request.auth.uid == userId impide acceso cruzado entre cuentas.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Todo lo demás queda denegado por defecto (no hay otra regla que lo permita).
  }
}
